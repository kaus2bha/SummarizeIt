{
  "manifest_version": 3,
  "name": "SummarizeIt",
  "version": "1.0",
  "description": "AI Powered Assistant To Summarize Webpages",

  "icons": {
    "128": "icons/icon128.png"
  },

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "sidePanel",
    "scripting",
    "contextMenus"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://localhost:8080/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "SummarizeIt",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}